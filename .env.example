# ==========================================
# Server-side Environment Variables
# ==========================================
# Query 连接配置
# TS3 使用 tcp + 10011
# TS6 使用 ssh + 10022
TS_SERVER_HOST=server.example.com
TS_QUERY_PROTOCOL=tcp
TS_QUERY_PORT=10011
TS_QUERY_USERNAME=serveradmin
TS_QUERY_PASSWORD=your_query_password_here
TS_QUERY_NICKNAME=WebQuery

# TS3 虚拟服务器选择
# 优先使用 TS_SERVER_ID；未设置时回退到 TS_VIRTUAL_PORT
TS_SERVER_ID=1
TS_VIRTUAL_PORT=9987

# 兼容旧配置：TS3_* 变量仍然可用

# 连接超时时间 (毫秒)
TS_CONNECTION_TIMEOUT=30000
# 缓存时间 (毫秒)
TS_CACHE_TTL=30000

# Rate Limiting 配置
# 仅在可信反向代理之后部署时开启；开启后才会信任 x-forwarded-for / x-real-ip
TRUST_PROXY_HEADERS=false
RATE_LIMIT_WINDOW_MS=60000
# 1/分钟 最多请求次数
RATE_LIMIT_MAX_REQUESTS=30
# 最多保留多少个限流键，避免内存无限增长
RATE_LIMIT_MAX_KEYS=5000

# ==========================================
# Runtime Display Configuration (公开)
# ==========================================
# 服务器显示配置
SERVER_NAME=页面显示的服务器名称_here
SERVER_DESCRIPTION=页面显示的服务器描述_here
SERVER_ADDRESS=页面显示的服务器地址_here
# 可选：频道白名单，逗号分隔；配置后白名单频道始终显示，当前有人频道也始终显示
DISPLAY_CHANNEL_NAMES=大厅,聊天室,APEX,CS:GO,VALORANT
